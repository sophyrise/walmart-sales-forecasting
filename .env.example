# Copy to .env and fill in. .env is gitignored — never commit real credentials.

# Kaggle API (Account > Settings > Create New Token)
KAGGLE_USERNAME=your_username
KAGGLE_KEY=your_api_key

# MLflow on DagsHub
MLFLOW_TRACKING_URI=https://dagshub.com/your_username/walmart-sales-forecasting.mlflow
MLFLOW_TRACKING_USERNAME=your_username
MLFLOW_TRACKING_PASSWORD=your_dagshub_token

# Weights & Biases (optional, for neural nets)
WANDB_API_KEY=your_wandb_key
WANDB_PROJECT=walmart-forecasting

# On Kaggle: add these same keys under "Add-ons > Secrets" instead of .env.
